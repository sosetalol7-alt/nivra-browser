include "mozilla/ipc/ByteBufUtils.h";

namespace mozilla {
namespace glean {

[ChildProc=Content]
protocol PFOGTransport {
parent:
    async FOGData(ByteBuf buf);

child:
    async FlushFOGData() returns (ByteBuf buf);
};

} // namespace glean
} // namespace mozilla
