with Files("**"):
    BUG_COMPONENT = ("Firefox", "IP Protection")

XPI_NAME = "ipp-activator"
XPI_PKGNAME = "ipp-activator@mozilla.com"

DIST_SUBDIR = ""

# NOTE: Please make sure that all files listed in here are in sync with the ones
# meant to be packaged in the add-on XPI file.

FINAL_TARGET_FILES += [
    "../extension/bg.js",
    "../manifest.json",
]

FINAL_TARGET_FILES.breakages += [
    "/browser/extensions/ipp-activator/extension/breakages/**"
]
FINAL_TARGET_FILES.conditions += [
    "/browser/extensions/ipp-activator/extension/conditions/**"
]
FINAL_TARGET_FILES.api.parent += [
    "/browser/extensions/ipp-activator/extension/api/parent/**"
]
FINAL_TARGET_FILES.api.schemas += [
    "/browser/extensions/ipp-activator/extension/api/schemas/**"
]
