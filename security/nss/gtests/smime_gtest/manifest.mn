CORE_DEPTH = ../..
DEPTH      = ../..
MODULE = nss

CPPSRCS = \
      smime_unittest.cc \
      $(NULL)

INCLUDES += -I$(CORE_DEPTH)/gtests/google_test/gtest/include \
            -I$(CORE_DEPTH)/gtests/common \
            -I$(CORE_DEPTH)/cpputil

REQUIRES = nspr gtest

PROGRAM = smime_gtest

# Link the static smime archive directly. This allows the use of
# internal symbols like NSS_SMIMEUtil_CreateSMIMECapabilities,
# which are intentionally not exported from the shared smime library.
EXTRA_LIBS = $(DIST)/lib/$(LIB_PREFIX)gtest.$(LIB_SUFFIX) $(EXTRA_OBJS) \
             $(DIST)/lib/$(LIB_PREFIX)gtestutil.$(LIB_SUFFIX) \
             $(DIST)/lib/$(LIB_PREFIX)smime.$(LIB_SUFFIX)
