{
  "mcpServers": {
    "moz": {
      "type": "http",
      "url": "https://mcp-dev.moz.tools/mcp"
    },
    "firefox-devtools": {
      "type": "stdio",
      "command": "./mach",
      "args": [
        "--quiet",
        "devtools-mcp",
        "--pref",
        "remote.prefs.recommended=false",
        "--pref",
        "browser.smartwindow.enabled=true",
        "--enable-privileged-context",
        "--enable-script"
      ]
    }
  }
}
